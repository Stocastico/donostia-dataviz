# Normalize all text files to LF, both in the repo and in the working tree
# (avoids CRLF/LF churn between Windows and the Linux pipeline/CI, and silences
# the "LF will be replaced by CRLF" warning on Windows). eol=lf keeps the
# working-tree copies in LF too.
* text=auto eol=lf

# Known binaries — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.xlsx binary
*.xls  binary
*.zip  binary
*.woff binary
*.woff2 binary
*.shp  binary
*.shx  binary
*.dbf  binary
